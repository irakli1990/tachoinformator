{
  "name": "info-tachospeed",
  "version": "1.0.0",
  "description": "Info Tachospeed - Narzędzie komunikacji z klientami",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:installer": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "pl.infolab.tachospeed",
    "productName": "Info Tachospeed",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.icns",
      "category": "public.app-category.business",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "Info Tachospeed",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/sygnet-red.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Info Tachospeed",
      "runAfterFinish": true
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
